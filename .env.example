# CU Benchmark Suite — Machine Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is gitignored — safe to store credentials here.
# run.sh loads this automatically.

# ─── Docker image ─────────────────────────────────────────────────────────────
# Set this to your GHCR image once it's published.
# Format: ghcr.io/{github-org-or-username}/cu-bench:latest
CU_IMAGE=ghcr.io/yggdrasil-technologies/cu-bench:latest

# ─── Upload: where to send results before container exits ────────────────────
# SSH/rsync (recommended for home server):
#   CU_UPLOAD_DEST=bearj@192.168.1.10:/data/cu-results/
#   CU_UPLOAD_DEST=bearj@myserver.ddns.net:/data/cu-results/
CU_UPLOAD_DEST=

# HTTPS webhook (alternative — works through NAT/firewalls):
#   CU_UPLOAD_WEBHOOK=https://myserver.com/bench/upload
CU_UPLOAD_WEBHOOK=

# ─── SSH key for upload ───────────────────────────────────────────────────────
# Path to SSH private key on the HOST machine.
# run.sh mounts this into the container automatically.
#   SSH_KEY_PATH=~/.ssh/id_ed25519
#   SSH_KEY_PATH=~/.ssh/id_bench
SSH_KEY_PATH=~/.ssh/id_ed25519

# ─── Results directory ────────────────────────────────────────────────────────
# Where to store results on the HOST (default: ./results next to run.sh)
# CU_RESULTS_DIR=/data/cu-results

# ─── Benchmark options ────────────────────────────────────────────────────────
# CU_QUICK=1           # fast mode: 1000 GEMM / 500 membw iters (~5 min total)
# CU_GPU_CLOCK=1700    # override GPU clock lock (MHz) — skip auto-detection
# CU_BENCH_MODEL=meta-llama/Llama-2-70b-hf   # model for inference benchmark
# CU_BENCH_MODEL_DIR=/data/models             # directory containing model weights
